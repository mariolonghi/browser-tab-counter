<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sending Apple Events (counting Safari/Chrome tabs) under the hardened
         runtime requires this entitlement + NSAppleEventsUsageDescription. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <!-- CPython needs writable+executable memory / JIT. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- py2app bundles its own Python framework and dylibs; allow loading them. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
